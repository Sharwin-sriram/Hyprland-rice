: 1782298406:0;cat > ~/themes/Main.qml << 'EOF'\
import QtQuick 2.11\
import QtQuick.Controls 2.4\
import SddmComponents 2.0\
\
Rectangle {\
    width: Screen.width\
    height: Screen.height\
    color: "#1a1a2e"\
\
    Column {\
        anchors.centerIn: parent\
        spacing: 16\
\
        Text {\
            text: userModel.currentUser\
            color: "white"\
            font.pixelSize: 24\
            anchors.horizontalCenter: parent.horizontalCenter\
        }\
\
        TextField {\
            id: passwordField\
            width: 300\
            placeholderText: "Password"\
            echoMode: TextInput.Password\
            Keys.onReturnPressed: sddm.login(userModel.currentUser, text, sessionIndex)\
        }\
\
        Button {\
            text: "Login"\
            anchors.horizontalCenter: parent.horizontalCenter\
            onClicked: sddm.login(userModel.currentUser, passwordField.text, sessionIndex)\
        }\
    }\
}\
EOF
