\
getAlbumArt() {\
    playerctl metadata mpris:artUrl 2>/dev/null\
}\
\
url=$(getAlbumArt)\
\
if [[ -z "$url" ]]; then\
    exit 0\
fi\
\
if [[ "$url" == http* ]]; then\
    curl -s "$url" -o "$ART_PATH"\
fi\

